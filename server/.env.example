# =============================================================
# Server environment variables
# Copy this file to .env for local development.
# In Vercel: add these under Project → Settings → Environment Variables
# =============================================================

# Node environment
NODE_ENV=production

# Port (Vercel ignores this; used for local dev only)
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/taji-cart

# JWT secret (use a long random string)
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRY=7d

# Allowed frontend origin — set to your Vercel client deployment URL
FRONTEND_URL=https://your-client-deployment.vercel.app

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# M-Pesa
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://your-server-deployment.vercel.app/api/mpesa/callback

# Pesapal
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_URL=https://your-server-deployment.vercel.app/api/pesapal/ipn

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-server-deployment.vercel.app/api/auth/google/callback

# Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Deepgram (voice transcription)
DEEPGRAM_API_KEY=

# Hugging Face
HUGGINGFACE_API_KEY=
