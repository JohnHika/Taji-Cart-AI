# =============================================================
# Server environment variables
# Copy this file to .env for local development.
# In Vercel: add these under Project → Settings → Environment Variables
# =============================================================

# Node environment
NODE_ENV=production

# Port (Vercel ignores this; used for local dev only)
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nawiri-hari

# JWT secret (use a long random string)
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRY=7d

# Allowed frontend origin — set to your Vercel client deployment URL
FRONTEND_URL=https://your-client-deployment.vercel.app

# Public backend origin used by backend-generated links outside Render defaults
SERVER_URL=https://your-backend-origin.example.com
BACKEND_URL=https://your-backend-origin.example.com

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# M-Pesa (POS in-store checkout only, Safaricom Daraja direct)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://your-backend-origin.example.com/api/mpesa/callback

# Jenga / Finserve (account-based M-Pesa STK push settlement, online customer checkout)
JENGA_ENV=sandbox
JENGA_API_KEY=
JENGA_MERCHANT_CODE=
JENGA_CONSUMER_SECRET=
# RSA private key (PEM). Store escaped newlines as \n in Vercel/Render and this
# code will restore them — never commit the actual key to source control.
JENGA_PRIVATE_KEY=
JENGA_ACCOUNT_NUMBER=
JENGA_MERCHANT_NAME=
JENGA_CALLBACK_URL=https://your-backend-origin.example.com/api/jenga/callback

# Foot delivery geofence (Nairobi CBD)
FOOT_DELIVERY_CBD_RADIUS_KM=3
NAIROBI_CBD_CENTER_LAT=-1.2810399
NAIROBI_CBD_CENTER_LNG=36.8235669

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Leave false until the branded OAuth/callback domain is publicly reachable.
GOOGLE_CALLBACK_BRANDED_READY=false
# Recommended when using a branded OAuth/callback domain. If omitted on Render,
# the server falls back to RENDER_EXTERNAL_URL for the Google callback.
GOOGLE_CALLBACK_URL=https://api.your-domain.example/api/auth/google/callback

# Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Deepgram (voice transcription)
DEEPGRAM_API_KEY=

# Hugging Face
HUGGINGFACE_API_KEY=
