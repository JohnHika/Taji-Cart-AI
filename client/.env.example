# =============================================================
# Client environment variables
# Copy this file to .env.local for local development.
# In Vercel: add these under Project → Settings → Environment Variables
# =============================================================

# Primary backend origin for normal API traffic (no trailing slash)
# Example: https://taji-cart-api.onrender.com
VITE_SERVER_URL=https://your-backend-origin.example.com

# Optional secondary backend alias for the same API traffic.
# Keep this aligned with VITE_SERVER_URL unless you intentionally need both.
VITE_BACKEND_URL=https://your-backend-origin.example.com

# Optional branded OAuth entry point used only for Google sign-in.
# Example: https://api.nawirihairke.com
# Leave blank unless that hostname is live and proxies /api/auth/* to the backend.
VITE_OAUTH_BASE_URL=

# Enable branded OAuth only after the branded hostname is confirmed live.
# Until this is "true", Google sign-in falls back to VITE_SERVER_URL / VITE_BACKEND_URL.
VITE_BRANDED_OAUTH_READY=false

# Stripe publishable key (safe to expose in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx

# Optional: override the backend port used for local dev proxy fallback
# VITE_API_PORT=3001
